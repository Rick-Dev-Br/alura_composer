{
    "name": "rick-dev-br/teste-alura",
    "version": "1.0.0",
    "description": "este é apenas um teste alura",
    "autoload": {
        "psr-4": {
    "Alura\\BuscadorDeCursos\\Model\\": "src/Model/"
    }
    },
    "authors": [
        {
            "name": "Rick-Dev-Br",
            "email": "henrique_rickgamer@hotmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "symfony/dom-crawler": "^8.0",
        "guzzlehttp/guzzle": "^7.10",
        "symfony/css-selector": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0",
        "phan/phan": "^6.0"
    },
    "scripts": {
        "fix": "php-cs-fixer fix",
        "cs": "phpcs --standard=PSR12 src",
        "test": "phpunit tests\\TestBuscadorDeCursos.php",
        "phan": "php vendor/bin/phan --allow-polyfill-parser",
        "check": [
            "@phan",
            "@cs",
            "@test"
        ],
        "post-update-cmd": [
            "@test"
        ]
        
    },
    "scripts-descriptions": {
        "check": "Executa todas as verificações de qualidade de código e testes"
    }
}
